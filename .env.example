# Copy this file to .env and replace the client values for the profile(s) you run.
MYDATUM_ISSUER=https://auth.staging.mydatum.ai

REACT_MYDATUM_CLIENT_ID=replace-with-public-client-id
REACT_MYDATUM_REDIRECT_URI=http://127.0.0.1:4173/auth/callback
REACT_MYDATUM_SCOPES=openid
REACT_PORT=4173

NODE_MYDATUM_CLIENT_ID=replace-with-partner-client-id
NODE_MYDATUM_CLIENT_SECRET=replace-with-partner-client-secret
NODE_MYDATUM_REDIRECT_URI=http://127.0.0.1:3000/auth/callback
NODE_MYDATUM_SCOPES=openid
NODE_SESSION_SECRET=replace-with-at-least-32-random-characters
NODE_PORT=3000

DJANGO_MYDATUM_CLIENT_ID=replace-with-partner-client-id
DJANGO_MYDATUM_CLIENT_SECRET=replace-with-partner-client-secret
DJANGO_MYDATUM_REDIRECT_URI=http://127.0.0.1:8000/auth/callback
DJANGO_MYDATUM_SCOPES=openid
DJANGO_SECRET_KEY=replace-with-at-least-50-random-characters
DJANGO_DEBUG=true
DJANGO_PORT=8000
